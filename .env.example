# SearXNG Configuration
SEARXNG_HOST=localhost
SEARXNG_PORT=8080
SEARXNG_BASE_PATH=/search
# SearXNG secret key for session encryption (generate with: openssl rand -hex 32)
SEARXNG_SECRET=searcrawl-local-secret-4e864c866431d2a28d752646338ac29f

# API Service Configuration
API_HOST=0.0.0.0
API_PORT=3000
APP_PORT=8000
APP_READER_PORT=8001

# Docker Image Overrides
# These are useful when the local Docker Hub mirror is unavailable.
PYTHON_IMAGE=mcr.microsoft.com/devcontainers/python:1-3.11-bookworm
REDIS_IMAGE=public.ecr.aws/docker/library/redis:7-alpine
SEARXNG_IMAGE=ghcr.io/searxng/searxng:latest
READER_IMAGE=ghcr.io/intergalacticalvariable/reader:latest
BROWSERLESS_IMAGE=ghcr.io/browserless/chromium:latest

# Crawler Configuration
DEFAULT_SEARCH_LIMIT=10
CONTENT_FILTER_THRESHOLD=0.6
WORD_COUNT_THRESHOLD=10
CRAWLER_POOL_SIZE=4
HTTP_EXTRACTOR_ENABLED=true
HTTP_EXTRACTOR_TIMEOUT_SECONDS=10
HTTP_EXTRACTOR_MAX_CONCURRENCY=20
HTTP_EXTRACTOR_MIN_CONTENT_LENGTH=300
# Benchmark-informed extraction strategy:
# reader_first: default, use Reader before HTTP/browser because benchmark showed best quality.
# http_first: lowest external Reader usage, then Reader fallback.
# quality_gated: HTTP first, but low-quality content is escalated to Reader.
CRAWL_EXTRACTION_STRATEGY=reader_first
CRAWL_QUALITY_GATE_ENABLED=true
CRAWL_MIN_QUALITY_SCORE=0.35

# Browser Fallback Configuration
# local: only local Chromium fallback
# remote: only Browserless/CDP cluster
# obscura: use the Obscura CLI as the browser fallback
# hybrid: Obscura first, then Browserless/CDP, then local Chromium fallback
BROWSER_BACKEND=local
BROWSERLESS_WS_URL=
BROWSER_REMOTE_TIMEOUT_SECONDS=45
BROWSER_REMOTE_MAX_CONCURRENCY=2
BROWSER_LOCAL_FALLBACK_ENABLED=false
BROWSER_LOCAL_MAX_CONCURRENCY=1
OBSCURA_BINARY=obscura
OBSCURA_TIMEOUT_SECONDS=45
OBSCURA_MAX_CONCURRENCY=4
OBSCURA_STEALTH_ENABLED=false
OBSCURA_WAIT_UNTIL=networkidle0
OBSCURA_DUMP_FORMAT=text
OBSCURA_ALLOW_PRIVATE_NETWORK=false

# Cache Configuration
# Enable or disable caching (true/false)
CACHE_ENABLED=true
# Redis connection URL
REDIS_URL=redis://localhost:6379/0
# Cache TTL in hours
CACHE_TTL_HOURS=120
SEARCH_CACHE_TTL_SECONDS=300

# Search Engine Configuration
SEARCH_PROVIDER=router
# Low-cost route order. "brave" is skipped unless EXTERNAL_SEARCH_ENABLED=true.
SEARCH_ROUTE_PROVIDERS=local,searxng,brave
EXTERNAL_SEARCH_ENABLED=false
EXTERNAL_SEARCH_FALLBACK_ONLY=true
SEARCH_ROUTER_MIN_RESULTS=3
# Default disabled search engines
DISABLED_ENGINES=wikipedia__general,currency__general,baidu__general,wikidata__general,lingva__general,qwant__general,startpage__general,dictzone__general,mymemory translated__general,brave__general
# Default enabled search engines
ENABLED_ENGINES=google__general,duckduckgo__general
# Search language (en for English, zh for Chinese, auto for automatic detection)
SEARCH_LANGUAGE=auto
BRAVE_SEARCH_API_BASE=https://api.search.brave.com/res/v1
BRAVE_SEARCH_API_KEY=

# Local Index Configuration
LOCAL_INDEX_ENABLED=true
LOCAL_INDEX_PATH=./data/searcrawl.sqlite3
LOCAL_INDEX_MIN_RESULTS=3

# Background Backfill Configuration
# Failed foreground crawls are queued and retried asynchronously with backoff.
BACKFILL_ENABLED=true
# Use redis for multiple crawler nodes; use local only for single-node dev.
BACKFILL_QUEUE_BACKEND=redis
BACKFILL_REDIS_KEY_PREFIX=searcrawl:backfill
BACKFILL_CLAIM_TTL_SECONDS=900
BACKFILL_BATCH_SIZE=3
BACKFILL_WORKER_INTERVAL_SECONDS=30
BACKFILL_MAX_ATTEMPTS=5
BACKFILL_BASE_DELAY_SECONDS=300
BACKFILL_MAX_DELAY_SECONDS=86400

# Service Registry Configuration
# etcd is optional. Use it to discover reader/crawler/api nodes in distributed mode.
ETCD_ENABLED=false
ETCD_ENDPOINTS=http://etcd:2379
ETCD_NAMESPACE=searcrawl
ETCD_TTL_SECONDS=30
ETCD_REFRESH_SECONDS=10
# Leave blank to use container hostname + process id.
ETCD_NODE_ID=
# Prefer setting this explicitly in distributed Docker/Kubernetes.
# Example: http://crawler-worker-1:3000
ETCD_NODE_ENDPOINT=
ETCD_DISCOVER_READERS=true
ETCD_REGISTER_SELF=true
# Comma-separated service names for this process, e.g. api,crawler.
ETCD_SELF_SERVICES=crawler
# Registers READER_URLS into etcd. Useful when reader images cannot self-register.
ETCD_REGISTER_READER_URLS=false

# Anti-Crawl Configuration
# Enable or disable anti-crawl features (true/false)
ANTI_CRAWL_ENABLED=true

# Enable IP proxy rotation (requires PROXY_LIST to be configured)
ENABLE_PROXY_ROTATION=false

# Enable random User-Agent rotation
ENABLE_USER_AGENT_ROTATION=true

# Enable random request delays between crawls
ENABLE_REQUEST_DELAY=true

# Enable random HTTP headers generation
ENABLE_RANDOM_HEADERS=true

# Enable realistic browser headers
ENABLE_BROWSER_HEADERS=true

# Request delay range in seconds (min and max)
MIN_REQUEST_DELAY=0.5
MAX_REQUEST_DELAY=3.0

# Proxy rotation mode: "random" or "sequential"
PROXY_ROTATION_MODE=random

# Include mobile User-Agents in rotation pool
USE_MOBILE_AGENTS=false

# Proxy list (comma-separated)
# Format: protocol://host:port or protocol://username:password@host:port
# Example: http://proxy1.com:8080,http://user:pass@proxy2.com:8080,socks5://proxy3.com:1080
PROXY_LIST=

# Custom User-Agents (comma-separated)
# Leave empty to use built-in User-Agent pool
# Example: Mozilla/5.0 (Custom Agent 1),Mozilla/5.0 (Custom Agent 2)
CUSTOM_USER_AGENTS=

# Reader Stage Configuration
# When enabled, Reader is used by the configured extraction strategy.
READER_ENABLED=true
READER_URL=http://reader:3000
# Comma-separated Reader endpoints. Requests are spread by stable hash and fail over.
# Example: http://reader-1:3000,http://reader-2:3000
READER_URLS=
READER_API_KEY=
READER_TIMEOUT_SECONDS=30
READER_MAX_CONCURRENCY=20
READER_MIN_CONTENT_LENGTH=300
